APP_NAME=FinClaw API
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
CORS_ORIGINS=*
DATABASE_URL=sqlite:///./finclaw.db
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets
DEFAULT_CASH_LIMIT=500
DEFAULT_MAX_ORDER_NOTIONAL=100
DEFAULT_MAX_DAILY_TRADES=3
DEFAULT_APPROVED_TICKERS=AAPL,MSFT,NVDA,GOOGL,BTCUSD,ETHUSD
ARMORIQ_ENABLED=false
ARMORIQ_API_KEY=your_armoriq_api_key
